# Veridex repo lives inside a multi-repo workspace (tx-odds-hack/).
# Allowlist strategy: ignore EVERYTHING, then re-include only the Veridex deliverable.
/*

# --- re-include the Veridex deliverable ---
!/.gitignore
!/.dockerignore
!/README.md
!/pyproject.toml
!/veridex/
!/veridex_agent/
!/tests/
!/scripts/
!/contracts/
!/apps/
!/docs/
!/Dockerfile.agent

# planning/spec docs stay LOCAL — never pushed (per project decision)
spec/
# local strategy notes stay LOCAL (docs/ is allowlisted for the committed WD-3 deploy guide only)
docs/strategy/

# --- within the allowed trees, still exclude secrets + build artifacts ---
veridex/.env
veridex/.env.local
**/.omc/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
.venv/

# live-integration spike: never commit node_modules or captured market data
scripts/txline_live/node_modules/
scripts/txline_live/captured_*.json
scripts/txline_live/*.tsbuildinfo
